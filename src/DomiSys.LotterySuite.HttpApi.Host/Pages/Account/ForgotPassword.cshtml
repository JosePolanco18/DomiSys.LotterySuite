@page
@using Microsoft.AspNetCore.Mvc.Localization
@using Volo.Abp.Account.Localization
@model DomiSys.LotterySuite.Pages.Account.ForgotPasswordModel
@inject IHtmlLocalizer<AccountResource> L
@{
    Layout = "~/Pages/Shared/_LoginLayout.cshtml";
}

<div class="login-container">
    <!-- Left Panel - Forgot Password Form -->
    <div class="login-form-panel">
        <div class="login-form-wrapper">
            <!-- Header -->
            <div class="login-header">
                <h1 class="login-title">¿Olvidaste tu contraseña?</h1>
                <p class="login-subtitle">Ingresa tu correo electrónico para recuperarla</p>
            </div>

            @if (Model.EmailSent)
            {
                <div class="alert-success">
                    <div class="alert-success-title">
                        ✓ Correo enviado
                    </div>
                    <p class="alert-success-message">
                        Se ha enviado un correo con las instrucciones para restablecer tu contraseña.
                        Por favor, revisa tu bandeja de entrada.
                    </p>
                </div>

                <div class="form-actions">
                    <a href="~/Account/Login" class="btn btn-secondary">
                        Volver al inicio de sesión
                    </a>
                </div>
            }
            else
            {
                <form method="post" id="forgotPasswordForm">
                    <!-- Validation Summary -->
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="validation-summary">
                            <div class="validation-summary-title">
                                Error de validación
                            </div>
                            <ul class="validation-summary-errors">
                                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                {
                                    <li>@error.ErrorMessage</li>
                                }
                            </ul>
                        </div>
                    }

                    <!-- Email Field -->
                    <div class="form-group">
                        <label for="ForgotPasswordInput_Email" class="form-label">
                            Correo electrónico
                        </label>
                        <input asp-for="ForgotPasswordInput.Email"
                               id="ForgotPasswordInput_Email"
                               class="form-control"
                               type="email"
                               autocomplete="email"
                               data-val="true"
                               data-val-required="Este campo es requerido"
                               data-val-email="Ingrese un correo electrónico válido"
                               placeholder="correo@ejemplo.com" />
                        <span asp-validation-for="ForgotPasswordInput.Email" class="invalid-feedback"></span>
                    </div>

                    <!-- Submit Button -->
                    <button type="submit"
                            id="forgotPasswordButton"
                            class="btn btn-primary">
                        <span class="btn-label">Enviar instrucciones</span>
                    </button>

                    <!-- Back to Login Link -->
                    <div class="form-footer">
                        <a href="~/Account/Login" class="link-primary">
                            ← Volver al inicio de sesión
                        </a>
                    </div>
                </form>
            }
        </div>
    </div>

    <!-- Right Panel - Brand -->
    <div class="login-brand-panel">
        <div class="login-brand-content">
            <div class="login-brand-logo">
                <h1>DomiSys</h1>
            </div>
            <h2 class="login-brand-title">Sistema Financiero</h2>
            <p class="login-brand-subtitle">Gestión integral para cooperativas</p>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/js/forgot-password.js"></script>
}
